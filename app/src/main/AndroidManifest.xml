<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- ML Kit GenAI Speech Recognition declares minSdk=26; the on-device
         datasource is gated at runtime by Build.VERSION.SDK_INT >= 31, so
         keeping app minSdk=24 is safe. -->
    <uses-sdk
        tools:overrideLibrary="com.google.mlkit.genai.speechrecognition,com.google.mlkit.genai.common" />

    <application
        android:name=".LuziaApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LuziaTestDavid">
        <!-- Allows macrobenchmark + baseline-profile collectors to trace
             this app on user-build devices. Harmless in debug builds. -->
        <profileable
            android:shell="true"
            tools:targetApi="29" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.LuziaTestDavid"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>